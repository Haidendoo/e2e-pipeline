# ============================================================
# EdgeX Foundry — Environment Configuration
# ============================================================
# Cấu hình cho docker-compose-no-secty.yml
# ============================================================

# ─── MQTT-Kafka Bridge ──────────────────────────────────────
# Kafka bootstrap servers của E2E pipeline
# Nếu cùng máy: localhost:9094
# Nếu máy khác: <IP của máy chạy E2E pipeline>:9094
KAFKA_BOOTSTRAP_SERVERS=host.docker.internal:9094

# ─── Device Registration ────────────────────────────────────
# IP của thiết bị biên (Raspberry Pi hoặc máy local gửi data)
# Dùng trong init-registration container để đăng ký device
EDGEX_DEVICE_ADDRESS=192.168.1.6
EDGEX_DEVICE_PORT=59986
