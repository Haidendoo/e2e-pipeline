# ============================================================
# EdgeX App Service — Kafka Export Configuration
# ============================================================
# File này được dùng bởi app-service-configurable trong
# docker-compose-no-secty.yml để export EdgeX events ra Kafka.
#
# Service sẽ:
#   1. Subscribe EdgeX internal MessageBus (MQTT)
#   2. Filter events từ device RPi4-REST-v2
#   3. Transform payload thành JSON
#   4. Publish tới Kafka topic: edgex_system_metrics
# ============================================================

# ─── Service Identity ────────────────────────────────────────
EDGEX_PROFILE=http-export
SERVICE_HOST=edgex-app-kafka-export
EDGEX_SECURITY_SECRET_STORE=false

# ─── Source: EdgeX MessageBus (Internal MQTT) ───────────────
TRIGGER_TYPE=edgex-messagebus
TRIGGER_EDGEXMESSAGEBUS_SUBSCRIBEHOST_HOST=edgex-mqtt-broker
TRIGGER_EDGEXMESSAGEBUS_SUBSCRIBEHOST_PORT=1883
TRIGGER_EDGEXMESSAGEBUS_SUBSCRIBEHOST_PROTOCOL=tcp
TRIGGER_EDGEXMESSAGEBUS_SUBSCRIBEHOST_TOPICS=edgex/events/device/#

# ─── Pipeline Functions ─────────────────────────────────────
PIPELINE_EXECUTIONORDER=FilterByDeviceName,Transform,HTTPExport
PIPELINE_FUNCTIONS_FILTERBYDEVICENAME_PARAMETERS_DEVICENAMES=RPi4-REST-v2,RPi4-MQTT
PIPELINE_FUNCTIONS_TRANSFORM_PARAMETERS_TYPE=json

# ─── Sink: HTTP Export to Kafka REST Proxy (alternative) ────
# Nếu dùng Kafka REST proxy, uncomment và cấu hình dưới đây:
# PIPELINE_FUNCTIONS_HTTPEXPORT_PARAMETERS_URL=http://kafka-rest:8082/topics/edgex_system_metrics
# PIPELINE_FUNCTIONS_HTTPEXPORT_PARAMETERS_MIMETYPE=application/vnd.kafka.json.v2+json
# PIPELINE_FUNCTIONS_HTTPEXPORT_PARAMETERS_CONTINUEONFINALERR=true

# ─── Sink: MQTT Export tới Kafka MQTT Bridge ────────────────
# Alternative: dùng MQTT-Kafka bridge
PIPELINE_EXECUTIONORDER=FilterByDeviceName,Transform,MQTTExport
PIPELINE_FUNCTIONS_MQTTEXPORT_PARAMETERS_BROKERADDRESS=tcp://edgex-mqtt-broker:1883
PIPELINE_FUNCTIONS_MQTTEXPORT_PARAMETERS_TOPIC=edgex_system_metrics_raw
PIPELINE_FUNCTIONS_MQTTEXPORT_PARAMETERS_CLIENTID=edgex-kafka-export
PIPELINE_FUNCTIONS_MQTTEXPORT_PARAMETERS_RETAIN=false
PIPELINE_FUNCTIONS_MQTTEXPORT_PARAMETERS_AUTORECONNECT=true
